VITE_APP_NAME=Pay Qist

# Leave empty when using the unified server (npm run dev / npm start)
VITE_API_BASE_URL=

# Comma-separated browser origins allowed to call the API (server-side)
ALLOWED_ORIGINS=http://localhost:8787,http://127.0.0.1:8787

# Server
PORT=8787
NODE_ENV=development

# Admin account (seeded on server start — use strong unique values in production)
ADMIN_EMAIL=admin@payqist.com
ADMIN_PASSWORD=CHANGE_ME_dev_only_min_8_chars

# Required in production: at least 32 random characters
SESSION_SECRET=CHANGE_ME_use_openssl_rand_hex_32

# Required in production: canonical public URL (used for HTTPS redirects)
APP_URL=http://localhost:8787

# Set to true only for demos without a real payment gateway (never in live production)
ALLOW_MOCK_CHECKOUT=false

# --- Vercel Storage (Marketplace) ---
# Vercel Blob — use read/write token OR linked-project OIDC + store id (local dev)
BLOB_READ_WRITE_TOKEN=
BLOB_STORE_ID=
# VERCEL_OIDC_TOKEN=   # auto-filled by: npx vercel env pull .env --yes

# Local dev workflow:
#   npx vercel env pull .env.development.local --yes   # Vercel secrets (Blob, etc.)
#   Keep app settings (PORT, ADMIN_*, SESSION_SECRET, etc.) in .env

# Verification email API (Gmail SMTP recommended with an App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Pay Qist
