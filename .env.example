VITE_APP_NAME=Pay Qist
VITE_ADMIN_EMAIL=admin@payqist.com

# Leave empty when using the unified server (npm run dev / npm start)
VITE_API_BASE_URL=

# Comma-separated browser origins allowed to call the API (server-side)
ALLOWED_ORIGINS=http://localhost:8787

# Server
PORT=8787
NODE_ENV=development
ADMIN_EMAIL=admin@payqist.com
ADMIN_PASSWORD=admin123
SESSION_SECRET=change-this-in-production

# Verification email API (Gmail SMTP recommended with an App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Pay Qist
