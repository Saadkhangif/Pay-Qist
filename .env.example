VITE_APP_NAME=Pay Qist
VITE_ADMIN_EMAIL=your_new_admin@example.com

# Optional Firebase config. When these are set, the app can be wired to real Firebase services.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Verification email API (Gmail SMTP recommended with an App Password)
VITE_API_BASE_URL=http://localhost:8787
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Pay Qist