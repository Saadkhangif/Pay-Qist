{
  "name": "pay-qist",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm run dev -w server",
    "build": "npm run build -w client",
    "env:pull": "vercel env pull .env.vercel.tmp --environment=development --yes && node scripts/merge-env.mjs .env.vercel.tmp",
    "lint": "eslint client server api scripts",
    "preview": "npm run preview -w client",
    "start": "npm run start -w server"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "eslint": "^9.6.0",
    "typescript": "^5.5.3",
    "vercel": "^54.15.0"
  }
}
